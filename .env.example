# ==================================================
# DiaExpress Client (frontend) — .env.example
# Scope: apps/diaexpress-client
# ==================================================
# Public variables must start with NEXT_PUBLIC_.

# APP
NODE_ENV=development
PORT=3000

# ==================================================
# API URLS (canonical + backward-compatible aliases)
# ==================================================
# Canonical for current repo architecture
NEXT_PUBLIC_DIAEXPRESS_API_BASE_URL=http://localhost:5000

# Legacy aliases (kept for compatibility with shared API wrappers)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:5000/api/v1/admin
NEXT_PUBLIC_LOGISTICS_API_BASE_URL=http://localhost:5000

# ==================================================
# FRONTEND / ADMIN URLS
# ==================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3001

# Production examples
# NEXT_PUBLIC_SITE_URL=https://www.diaexpress.com
# NEXT_PUBLIC_DIAEXPRESS_API_BASE_URL=https://api.diaexpress.com
# NEXT_PUBLIC_ADMIN_APP_URL=https://admin.diaexpress.com

# ==================================================
# CLERK (FRONTEND AUTH)
# ==================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Canonical backend JWT template name used by token bridge
NEXT_PUBLIC_DIAEXPRESS_CLERK_JWT_TEMPLATE=diaexpress-backend

# Legacy aliases (optional)
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=diaexpress-backend
NEXT_PUBLIC_CLERK_TEMPLATE=diaexpress-backend

# ==================================================
# PAYMENTS / FEATURES
# ==================================================
NEXT_PUBLIC_ENABLE_DIAPAY=true
# Legacy inverse flag (keep empty unless needed)
NEXT_PUBLIC_DIAPAY_DISABLED=

# Network robustness
NEXT_PUBLIC_API_TIMEOUT_MS=8000
NEXT_PUBLIC_API_RETRY_COUNT=2
